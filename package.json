{
  "name": "skopecreep",
  "version": "0.3.0",
  "description": "Audit the configuration and granted scope of your AI coding tools (Claude Code, Codex, Cursor, Windsurf, Copilot) and flag risky config.",
  "type": "module",
  "bin": {
    "skopecreep": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "Geet Pradhan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gprad-Work/skopecreep.git"
  },
  "homepage": "https://github.com/Gprad-Work/skopecreep#readme",
  "bugs": {
    "url": "https://github.com/Gprad-Work/skopecreep/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome ci .",
    "format": "biome check --write .",
    "test": "npm run build && vitest run",
    "coverage": "npm run build && vitest run --coverage"
  },
  "keywords": [
    "ai",
    "security",
    "audit",
    "mcp",
    "claude-code",
    "codex",
    "cursor",
    "scope-creep",
    "ai-agents",
    "least-privilege"
  ],
  "license": "MIT",
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "picocolors": "^1.1.1",
    "smol-toml": "^1.3.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
